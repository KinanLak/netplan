{
  "name": "netplan-create",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently 'bun run db' 'bun run web'",
    "web": "vite dev",
    "db": "convex dev",
    "build": "vite build",
    "lint": "oxlint --fix",
    "format": "oxfmt --write",
    "tsc": "tsgo --noEmit --pretty",
    "check": "bun run tsc && bun run lint && bun run format && bun test",
    "desktop:dev": "concurrently -k 'bun run db' 'bun run web --host 127.0.0.1 --port 3000' 'NETPLAN_DESKTOP_URL=http://127.0.0.1:3000 electrobun dev'",
    "desktop:build": "bun run build && NETPLAN_ELECTROBUN_INCLUDE_WEB_BUILD=1 electrobun build --env=stable",
    "desktop:build:dev": "bun run build && NETPLAN_ELECTROBUN_INCLUDE_WEB_BUILD=1 electrobun build",
    "desktop:dev:build": "bun run desktop:build:dev"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@fontsource-variable/plus-jakarta-sans": "^5.2.8",
    "@hugeicons/core-free-icons": "^4.1.4",
    "@hugeicons/react": "^1.1.6",
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/react-devtools": "^0.10.5",
    "@tanstack/react-router": "^1.170.4",
    "@tanstack/react-router-devtools": "^1.167.0",
    "@tanstack/react-start": "^1.168.6",
    "@xyflow/react": "^12.10.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "convex": "^1.39.1",
    "electrobun": "^1.18.1",
    "nitro": "3.0.260429-beta",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "shadcn": "^4.7.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@happy-dom/global-registrator": "^20.9.0",
    "@rolldown/plugin-babel": "^0.2.3",
    "@tanstack/devtools-vite": "^0.7.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/babel__core": "^7.20.5",
    "@types/node": "^25.9.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.184.1",
    "@typescript/native-preview": "7.0.0-dev.20260519.1",
    "@vitejs/plugin-react": "^6.0.2",
    "babel-plugin-react-compiler": "^1.0.0",
    "concurrently": "^9.2.1",
    "convex-test": "^0.0.53",
    "eslint-plugin-react-hooks": "^7.1.1",
    "happy-dom": "^20.9.0",
    "oxfmt": "^0.51.0",
    "oxlint": "^1.66.0",
    "oxlint-tsgolint": "^0.23.0",
    "react-scan": "^0.5.6",
    "vite": "^8.0.13"
  }
}