{
  "name": "netplan-create",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently 'bun run db' 'bun run web'",
    "web": "vite dev",
    "db": "convex dev",
    "build": "vite build",
    "lint": "oxlint --fix --deny-warnings",
    "format": "oxfmt --write",
    "tsc": "tsc --noEmit --pretty",
    "check": "bun run tsc && bun run lint && bun run format && bun test",
    "desktop:dev": "concurrently -k 'bun run db' 'bun run web --host 127.0.0.1 --port 3000' 'NETPLAN_DESKTOP_URL=http://127.0.0.1:3000 electrobun dev'",
    "desktop:build": "bun run build && NETPLAN_ELECTROBUN_INCLUDE_WEB_BUILD=1 electrobun build --env=stable",
    "desktop:build:dev": "bun run build && NETPLAN_ELECTROBUN_INCLUDE_WEB_BUILD=1 electrobun build",
    "desktop:dev:build": "bun run desktop:build:dev",
    "bench:engine": "bun run scripts/bench-engine.ts",
    "perf:render": "bun test test/perf/renderCounts.test.tsx"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@fontsource-variable/plus-jakarta-sans": "^5.2.8",
    "@hugeicons/core-free-icons": "^4.2.2",
    "@hugeicons/react": "^1.1.9",
    "@tailwindcss/vite": "^4.3.2",
    "@tanstack/react-devtools": "^0.10.8",
    "@tanstack/react-router": "^1.170.17",
    "@tanstack/react-router-devtools": "^1.167.0",
    "@tanstack/react-start": "^1.168.27",
    "@xyflow/react": "^12.11.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "convex": "^1.42.1",
    "electrobun": "^1.18.1",
    "nitro": "3.0.260429-beta",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "shadcn": "^4.13.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.2",
    "tw-animate-css": "^1.4.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@babel/core": "^8.0.1",
    "@happy-dom/global-registrator": "^20.10.6",
    "@rolldown/plugin-babel": "^0.2.3",
    "@tanstack/devtools-vite": "^0.8.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/babel__core": "^7.20.5",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.185.1",
    "@vitejs/plugin-react": "^6.0.3",
    "babel-plugin-react-compiler": "^1.0.0",
    "concurrently": "^10.0.3",
    "convex-test": "^0.0.54",
    "eslint-plugin-react-hooks": "^7.1.1",
    "happy-dom": "^20.10.6",
    "mitata": "^1.0.34",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.73.0",
    "oxlint-tsgolint": "^0.24.0",
    "react-scan": "^0.5.7",
    "typescript": "^7",
    "vite": "^8.1.4"
  }
}
